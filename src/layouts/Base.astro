---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  url?: string;
}

const {
  title = 'Scott Tomlins',
  description = 'Senior Data Analyst · Bristol, UK',
  url = 'https://stomlins.com',
} = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Scott Tomlins",
  "jobTitle": "Senior Data Analyst",
  "worksFor": {
    "@type": "Organization",
    "name": "Dyson",
  },
  "address": { "@type": "PostalAddress", "addressLocality": "Bristol, UK" },
  "url": "https://stomlins.com",
  "sameAs": [
    "https://linkedin.com/in/scotttomlins",
    "https://github.com/satomlins",
    "https://stomlins.medium.com",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <style>
      @font-face {
        font-family: 'Plus Jakarta Sans';
        src: url('/fonts/PlusJakartaSans-VariableFont_wght.woff2') format('woff2');
        font-weight: 100 800;
        font-style: normal;
        font-display: swap;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
